# Copy to infra/production.env on the server and replace every secret before release.

# Public hosts
CADDY_SITE_ADDRESS=penthouse.blog, api.penthouse.blog
API_HOST=api.penthouse.blog
PUBLIC_APP_URL=https://penthouse.blog
PUBLIC_API_URL=https://api.penthouse.blog
PUBLIC_SOCKET_URL=https://api.penthouse.blog
PUBLIC_ALTCHA_API_URL=https://api.penthouse.blog/api/v1/auth/challenge
CORS_ORIGIN=https://penthouse.blog
TRUST_PROXY=true
ACME_EMAIL=admin@penthouse.blog

# Host ports. On Unraid, map these to the externally forwarded ports you use.
API_BIND=127.0.0.1
API_PORT=3000
HTTP_PORT=8080
HTTPS_PORT=8443

# Database
POSTGRES_USER=penthouse
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=penthouse
POSTGRES_PORT=5434
DATABASE_URL=postgres://penthouse:replace-with-a-long-random-database-password@postgres:5432/penthouse

# API secrets
JWT_SECRET=replace-with-at-least-32-random-characters
ALTCHA_HMAC_KEY=replace-with-a-long-random-altcha-secret
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_SUBJECT=mailto:admin@penthouse.blog

# Upload and media limits
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25
UPLOAD_MAX_MB=25
MEDIASOUP_ENABLED=false
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=10100

# Production bootstrap invite. Do not use PENTHOUSE-ALPHA in production.
ALPHA_BOOTSTRAP_INVITE_CODE=replace-with-private-alpha-code
ALPHA_BOOTSTRAP_INVITE_LABEL=Production alpha invite
ALPHA_BOOTSTRAP_INVITE_MAX_USES=25
ALPHA_BOOTSTRAP_INVITE_EXPIRES_AT=
ALPHA_REVOKE_DEFAULT_INVITE=true

# Domains
ROOT_SITE_ADDRESS=penthouse.blog
API_SITE_ADDRESS=api.penthouse.blog

# Caddy ports on the TrueNAS host
CADDY_HTTP_PORT=9080
CADDY_HTTPS_PORT=9443

# PostgreSQL
POSTGRES_USER=penthouse
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=penthouse

# API secrets
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
ALTCHA_HMAC_KEY=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
CORS_ORIGIN=https://penthouse.blog
PUBLIC_APP_URL=https://penthouse.blog
LEGACY_APK_DOWNLOAD_PATH=/downloads/legacy/the-penthouse.apk
LEGACY_APK_STATUS=unavailable
UPLOAD_MAX_MB=25
ADMIN_BOOTSTRAP_USERNAME=
TEST_ACCOUNT_NOTICE_VERSION=alpha-v1
BACKUP_STATUS_PATH=/app/services/api/uploads/ops/backup-status.json

# External APIs
GIPHY_API_KEY=

# TrueNAS absolute paths
TRUENAS_POSTGRES_PATH=/mnt/Backup/penthouse-rebuild/postgres
TRUENAS_UPLOADS_PATH=/mnt/Backup/penthouse-rebuild/uploads
TRUENAS_DOWNLOADS_PATH=/mnt/Backup/penthouse-rebuild/downloads
TRUENAS_CADDY_DATA_PATH=/mnt/Backup/penthouse-rebuild/caddy-data
TRUENAS_CADDY_CONFIG_PATH=/mnt/Backup/penthouse-rebuild/caddy-config
TRUENAS_BACKUP_PATH=/mnt/Backup/penthouse-rebuild/backups/postgres
BACKUP_STATUS_HOST_PATH=/mnt/Backup/penthouse-rebuild/uploads/ops/backup-status.json

# Downloads
PUBLIC_DOWNLOADS_PATH=/mnt/Backup/penthouse-rebuild/downloads

# Android FCM is deferred; leave disabled unless reactivated.
FCM_SERVICE_ACCOUNT_FILE=/dev/null
FCM_SERVICE_ACCOUNT_PATH=

# Web Push VAPID keys
VAPID_PUBLIC_KEY=CHANGE_ME_GENERATE_WITH_WEB_PUSH
VAPID_PRIVATE_KEY=CHANGE_ME_GENERATE_WITH_WEB_PUSH
VAPID_SUBJECT=mailto:admin@penthouse.blog

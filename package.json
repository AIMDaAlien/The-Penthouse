{
  "name": "the-penthouse",
  "version": "2.1.0-alpha.0",
  "private": true,
  "description": "The Penthouse clean-room rebuild monorepo",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run --workspaces --if-present typecheck",
    "lint": "npm run --workspaces --if-present lint",
    "test": "npm run --workspaces --if-present test",
    "validate": "npm run typecheck && npm run test",
    "scenario:test": "node antigravity/scripts/run-scenarios.mjs",
    "release:gate": "node scripts/run-release-gate.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "vite": "^6.4.1"
  }
}

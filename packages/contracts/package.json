{
  "name": "@penthouse/contracts",
	"version": "4.0.0-alpha.1",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"production": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"src",
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "tsx --test test/**/*.test.ts"
	},
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}

# Database
DATABASE_URL=postgres://penthouse:penthouse@localhost:5434/penthouse

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CAPTCHA
ALTCHA_HMAC_KEY=dev-only-register-allows-any-token

# Public distribution
PUBLIC_APP_URL=http://localhost:5174
LEGACY_APK_DOWNLOAD_PATH=/downloads/legacy/the-penthouse.apk
LEGACY_APK_STATUS=unavailable

# Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=base64url-public-key
VAPID_PRIVATE_KEY=base64url-private-key
VAPID_SUBJECT=mailto:admin@penthouse.blog

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
# Production compose may use this alias; MAX_FILE_SIZE_MB wins when both are set.
UPLOAD_MAX_MB=10

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
